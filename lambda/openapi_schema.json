{
  "openapi": "3.0.3",
  "info": {
    "title": "Kinesis Data Streams Mode Optimizer",
    "description": "Analyzes Kinesis Data Streams usage patterns and recommends the optimal capacity mode (On-demand Standard, On-demand Advantage, or Provisioned). The agent prefers on-demand modes for reduced operational overhead and only recommends provisioned when there is a clear cost benefit with stable, predictable traffic.",
    "version": "1.0.0"
  },
  "paths": {
    "/analyzeStreams": {
      "get": {
        "operationId": "analyzeStreams",
        "summary": "Analyze all Kinesis Data Streams in the current region and provide mode recommendations",
        "description": "Lists all Kinesis Data Streams in the AWS account and region, collects CloudWatch metrics for the past 7 days, and generates capacity mode recommendations for each stream. Returns analysis including throughput patterns, throttling rates, shard utilization, and whether the account qualifies for On-demand Advantage mode.",
        "responses": {
          "200": {
            "description": "Analysis results with per-stream recommendations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "region": {
                      "type": "string",
                      "description": "AWS region analyzed"
                    },
                    "account_id": {
                      "type": "string",
                      "description": "AWS account ID"
                    },
                    "streams": {
                      "type": "array",
                      "description": "Per-stream analysis and recommendations",
                      "items": {
                        "type": "object"
                      }
                    },
                    "account_level_summary": {
                      "type": "object",
                      "description": "Account-wide summary including On-demand Advantage eligibility"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/generateReport": {
      "post": {
        "operationId": "generateReport",
        "summary": "Generate a full optimization report and store it in S3",
        "description": "Performs a complete analysis of all Kinesis Data Streams, generates a structured JSON report with recommendations, and stores it in the specified S3 bucket. Use this for scheduled reporting.",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "bucket_name": {
                    "type": "string",
                    "description": "S3 bucket name to store the report. If not provided, uses the default configured bucket."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Report generation summary with S3 location",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "report_id": {
                      "type": "string",
                      "description": "Unique report identifier"
                    },
                    "s3_bucket": {
                      "type": "string",
                      "description": "S3 bucket where report is stored"
                    },
                    "s3_key": {
                      "type": "string",
                      "description": "S3 object key for the report"
                    },
                    "generated_at": {
                      "type": "string",
                      "description": "ISO 8601 timestamp of report generation"
                    },
                    "total_streams_analyzed": {
                      "type": "integer",
                      "description": "Number of streams analyzed"
                    },
                    "streams_needing_change": {
                      "type": "integer",
                      "description": "Number of streams where a mode change is recommended"
                    },
                    "high_priority_actions": {
                      "type": "integer",
                      "description": "Number of high-priority recommendations"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/getStreamDetails": {
      "get": {
        "operationId": "getStreamDetails",
        "summary": "Get detailed metrics and recommendation for a specific stream",
        "description": "Retrieves detailed CloudWatch metrics, usage patterns, and a capacity mode recommendation for a single named Kinesis Data Stream.",
        "parameters": [
          {
            "name": "stream_name",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The name of the Kinesis Data Stream to analyze"
          }
        ],
        "responses": {
          "200": {
            "description": "Detailed stream analysis with recommendation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "stream_name": {
                      "type": "string"
                    },
                    "current_mode": {
                      "type": "string"
                    },
                    "current_shards": {
                      "type": "integer"
                    },
                    "metrics_summary": {
                      "type": "object"
                    },
                    "recommendation": {
                      "type": "string"
                    },
                    "reasoning": {
                      "type": "string"
                    },
                    "priority": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
